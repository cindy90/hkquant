# ============================================================================
# HK IPO Cornerstone Agent — .gitignore
# Replaces the legacy NACS .gitignore. See PROJECT_SPEC.md §10.6.
# ============================================================================

# --- Credentials & secrets ---
.env
.env.*
!.env.example
.secrets.baseline.local
*.pem
*.key

# --- Python bytecode / tool caches ---
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# --- Virtual envs ---
.venv/
venv/
env/

# --- uv ---
# uv.lock IS committed (deterministic builds).

# --- IDE / editors ---
.vscode/
.idea/
*.swp
.cursor/

# --- OS noise ---
.DS_Store
Thumbs.db
desktop.ini

# --- Runtime artifacts ---
outputs/
daily/
logs/
*.log

# --- Database (SQLite legacy + new ad-hoc) ---
*.db
*.sqlite
*.sqlite3
!data/nacs_real.db
!data/nacs_real.db.bak_*

# --- Data: PDFs and large raw downloads are NOT committed ---
data/raw/prospectuses/*.pdf
data/raw/prospectuses/*.PDF
data/processed/extractions/*.json
data/processed/extractions/*.parquet
data/knowledge_base/*.parquet
data/benchmarks/backtest_runs/*

# Keep .gitkeep so directory structure persists
!data/**/.gitkeep

# --- Vector store local data ---
qdrant_storage/

# --- Notebook outputs (commit only cleared cells) ---
notebooks/.ipynb_checkpoints/

# --- Build artifacts ---
build/
dist/
*.whl

# --- Temp / scratch ---
*.tmp
*.bak
scratch/

# --- Personal watchlist (privacy) ---
data/watchlist.json

# --- New project spec working dir (local-only) ---
# PROJECT_SPEC.md is the committed copy at repo root; the source folder stays local.
new_project_spec/

.claude/
