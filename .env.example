# HK IPO Cornerstone Agent — environment variables template
# Copy to .env and fill in real values. .env is gitignored.

# ---------- Environment ----------
ENVIRONMENT=dev                                 # dev | staging | prod
LOG_LEVEL=INFO

# ---------- LLM ----------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT_SECONDS=120
LLM_COST_DAILY_BUDGET_USD=20.0                  # per-user default (cost_guard)

# ---------- Prospectus parsing ----------
LLAMA_CLOUD_API_KEY=                            # required for LlamaParse primary path
PROSPECTUS_PARSER_MAX_PAGES=800

# ---------- Embeddings ----------
EMBEDDING_PROVIDER=local                        # local | voyage
VOYAGE_API_KEY=
BGE_MODEL_PATH=BAAI/bge-large-zh-v1.5

# ---------- Database (PostgreSQL) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hkipo
POSTGRES_USER=hkipo
POSTGRES_PASSWORD=hkipo
POSTGRES_POOL_SIZE=10
DATABASE_URL=postgresql+asyncpg://hkipo:hkipo@localhost:5432/hkipo

# ---------- Vector store (Qdrant) ----------
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ---------- Cache / queue (Redis) ----------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ---------- iFind data source ----------
# iFinDPy is installed manually from the Tonghuashun client; not on PyPI.
# Configure account credentials below (used by data/sources/ifind_client.py).
IFIND_USERNAME=
IFIND_PASSWORD=
IFIND_QPS_LIMIT=10

# ---------- HKEXnews ----------
HKEX_USER_AGENT=hk-ipo-agent/0.0 (research)
HKEX_RATE_LIMIT_PER_SEC=2

# ---------- API server ----------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_RATE_LIMIT_PER_MIN=60

# ---------- Auth (v1.2.1) ----------
JWT_SECRET=change-me-min-32-chars-long-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
SSO_PROVIDER=local                              # local | okta | azure_ad
SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# ---------- Alerts (v1.2) ----------
ALERT_EMAIL_TO=
ALERT_SLACK_WEBHOOK_URL=
ALERT_PAGERDUTY_INTEGRATION_KEY=

# ---------- Scheduler ----------
SCHEDULER_BACKEND=apscheduler                   # apscheduler (dev) | airflow (prod)
SCHEDULER_TIMEZONE=Asia/Hong_Kong
