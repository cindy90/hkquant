# HK IPO Cornerstone Agent — Environment variables template
# 复制为 .env 后填写实际值。所有变量遵循 pydantic-settings 双下划线嵌套约定：
#   HK_IPO__<SECTION>__<FIELD>   （映射到 common/settings.py 的 Settings.<section>.<field>）
#
# 优先级（高 → 低）：
#   1. 环境变量（HK_IPO__*）
#   2. 本 .env 文件
#   3. config/*.yaml
#   4. Pydantic 字段默认值
#
# 永远不要把真实 .env 提交到 git（.gitignore 已排除）。
# 仅 .env.example 入仓，作为字段清单。

# =============================================================================
# 通用 / Global
# =============================================================================

# dev | staging | prod  （prod 触发 HITL 强制开、JWT secret 启动断言等保护）
HK_IPO__ENVIRONMENT=dev

HK_IPO__LOG_LEVEL=INFO
HK_IPO__LOG_JSON=true

# 数据目录（默认为 repo_root/data）
# HK_IPO__DATA_DIR=/abs/path/to/data
# HK_IPO__OUTPUT_DIR=/abs/path/to/outputs

# =============================================================================
# PostgreSQL — 主数据库
# =============================================================================

HK_IPO__DATABASE__HOST=localhost
HK_IPO__DATABASE__PORT=5432
HK_IPO__DATABASE__NAME=hkipo
HK_IPO__DATABASE__USER=hkipo
HK_IPO__DATABASE__PASSWORD=hkipo
HK_IPO__DATABASE__POOL_SIZE=10

# docker-compose.yml 同步变量（POSTGRES_* 不带前缀，由 compose 读）
POSTGRES_DB=hkipo
POSTGRES_USER=hkipo
POSTGRES_PASSWORD=hkipo
POSTGRES_PORT=5432

# =============================================================================
# Qdrant — 向量库
# =============================================================================

HK_IPO__QDRANT__URL=http://localhost:6333
# 云端 Qdrant 才需要；本地 docker 留空
# HK_IPO__QDRANT__API_KEY=

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# =============================================================================
# Redis — 缓存 / 限流
# =============================================================================

HK_IPO__REDIS__URL=redis://localhost:6379/0
REDIS_PORT=6379

# =============================================================================
# LLM — KIMI/Moonshot 主、Anthropic 备（参见 ADR 0017）
# =============================================================================

# KIMI/Moonshot（OpenAI-compatible API） — 当前主路径
HK_IPO__LLM__KIMI_API_KEY=sk-replace-me
HK_IPO__LLM__KIMI_URL=https://api.moonshot.cn/v1

# Anthropic Claude — ADR 0002 原主路径，已 Superseded；保留 key 以便回退实验
# HK_IPO__LLM__ANTHROPIC_API_KEY=sk-ant-replace-me

HK_IPO__LLM__MAX_RETRIES=3
HK_IPO__LLM__TIMEOUT_SECONDS=120
# 单日 LLM 调用总成本上限 (USD)
HK_IPO__LLM__COST_DAILY_BUDGET_USD=20.0

# =============================================================================
# 招股书解析 — LlamaParse 主、PyMuPDF 备（ADR 0004）
# =============================================================================

# 不填则 PDF 解析回退到 PyMuPDF（功能可用但表格识别质量下降）
# HK_IPO__PROSPECTUS__LLAMA_CLOUD_API_KEY=llx-replace-me
HK_IPO__PROSPECTUS__PARSER_MAX_PAGES=800

# =============================================================================
# 嵌入模型
# =============================================================================

# local (BGE-large-zh-v1.5) | voyage
HK_IPO__EMBEDDING__PROVIDER=local
HK_IPO__EMBEDDING__BGE_MODEL_PATH=BAAI/bge-large-zh-v1.5
# 仅 provider=voyage 时需要
# HK_IPO__EMBEDDING__VOYAGE_API_KEY=

# =============================================================================
# iFind — 港股市场数据源（Phase 2 ETL + 补漏路径）
# =============================================================================

# iFind Python SDK 需要的登录凭证；iFindPy 不在 PyPI，需要厂商提供 wheel
HK_IPO__IFIND__USERNAME=
HK_IPO__IFIND__PASSWORD=
# QPS 节流（同花顺合约通常 10）
HK_IPO__IFIND__QPS_LIMIT=10

# =============================================================================
# FastAPI 服务（Phase 7）
# =============================================================================

HK_IPO__API__HOST=0.0.0.0
HK_IPO__API__PORT=8000
# JSON 列表，CORS 白名单；prod 严禁 ["*"]
HK_IPO__API__CORS_ORIGINS=["http://localhost:3000"]
# 每 IP 每分钟请求数上限
HK_IPO__API__RATE_LIMIT_PER_MIN=60

# =============================================================================
# Auth — 本地 JWT（SSO 延 Phase 9 ADR 0011）
# =============================================================================

# 生产 env 必须覆盖此默认值；R2-7 启动断言会拦截 default 字面量
HK_IPO__AUTH__JWT_SECRET=change-me-min-32-chars-long-secret-here
HK_IPO__AUTH__JWT_ALGORITHM=HS256
HK_IPO__AUTH__JWT_ACCESS_TOKEN_TTL_SECONDS=3600
HK_IPO__AUTH__JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# SSO（Phase 9 启用）
HK_IPO__AUTH__SSO_PROVIDER=local
HK_IPO__AUTH__SSO_ISSUER_URL=
HK_IPO__AUTH__SSO_CLIENT_ID=
HK_IPO__AUTH__SSO_CLIENT_SECRET=
HK_IPO__AUTH__SSO_REDIRECT_URI=

# =============================================================================
# Scheduler（Phase 7.5）
# =============================================================================

# apscheduler (dev/test) | airflow (prod) — R8-5 会加 prod 强制 airflow 校验
HK_IPO__SCHEDULER__BACKEND=apscheduler
HK_IPO__SCHEDULER__TIMEZONE=Asia/Hong_Kong

# =============================================================================
# Orchestrator — LangGraph 主图（ADR 0010）
# =============================================================================

# Human-in-the-loop。prod env 必须 true（R2-1 会加启动断言）
HK_IPO__ORCHESTRATOR__ENABLE_HITL=false

# Bull/Bear/Devil 辩论轮数硬上限
HK_IPO__ORCHESTRATOR__DEBATE_MAX_ROUNDS=3
# Jaccard 早停阈值
HK_IPO__ORCHESTRATOR__DEBATE_JACCARD_THRESHOLD=0.6

# 系统版本 — 任何 config/prompt/model 变动需 bump
HK_IPO__ORCHESTRATOR__SYSTEM_VERSION=1.0.0
