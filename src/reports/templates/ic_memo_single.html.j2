{% extends "_base.html.j2" %}

{# Defaults: rec_main 是 mid/final 那条记录, 用于决策大字 #}
{% set rec_main = records | selectattr("scenario", "in", ["mid", "final"]) | list %}
{% if rec_main %}
  {% set rec_main = rec_main[0] %}
{% else %}
  {% set rec_main = records[0] %}
{% endif %}

{% block content %}

<header class="memo-header">
  <h1>{{ rec_main.stock_code }}
      {% if rec_main.name %}<span style="font-weight: 400; color: var(--text-muted);">{{ rec_main.name }}</span>{% endif %}</h1>
  <p class="subtitle">
    <span class="badge badge-{{ rec_main.status or 'listed' }}">{{ rec_main.status or '?' }}</span>
    {% if rec_main.listing_chapter %}
      · chapter: <code>{{ rec_main.listing_chapter }}</code>
    {% endif %}
    {% if rec_main.gics_l2 %}
      · GICS: {{ rec_main.gics_l2 }}
    {% endif %}
  </p>
  <div class="meta">
    <span>asof: <strong>{{ asof | fmt_date }}</strong></span>
    {% if rec_main.listing_date %}
      <span>listing: <strong>{{ rec_main.listing_date | fmt_date }}</strong></span>
    {% endif %}
    {% if rec_main.expected_listing_date %}
      <span>expected: <strong>{{ rec_main.expected_listing_date | fmt_date }}</strong></span>
    {% endif %}
    {% if snap.snapshot_id %}
      <span>panel: <code>{{ snap.snapshot_id }}</code> (n={{ snap.n_ipos_in_universe }}{% if snap.regime_score is not none %}, regime={{ snap.regime_score | num(3) }}{% endif %})</span>
    {% endif %}
  </div>
</header>

{# ====== Verdict (仅当只有一个 scenario 时显示大字; 多 scenario 用表格) ====== #}
{% if records | length == 1 %}
<div class="verdict">
  <span class="badge badge-{{ rec_main.decision }}">{{ rec_main.decision }}</span>
  <span class="position">{{ "%.0f%%"|format(rec_main.position_pct * 100) }}</span>
  <span class="nacs-value">
    NACS_adj <strong>{{ rec_main.nacs_adjusted | num(4) }}</strong>
    &nbsp;·&nbsp; raw {{ rec_main.nacs_raw | num(4) }}
  </span>
</div>

{# ====== Investment thesis (顶部综合段) ====== #}
{% if thesis %}
<section class="thesis">
  <p class="headline">{{ thesis.headline }}</p>

  {% if thesis.drivers %}
  <div class="group">
    <h4>主驱动 ({{ thesis.drivers | length }})</h4>
    <ul class="bullets">
      {% for d in thesis.drivers %}
      <li class="driver">
        <strong>{{ d.name }}</strong>
        {% if d.score is not none %} (score {{ d.score | num(1) }}){% endif %}
        {% if d.reason %}<span class="reason-detail">{{ d.reason }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {% if thesis.risks %}
  <div class="group">
    <h4>主风险 ({{ thesis.risks | length }})</h4>
    <ul class="bullets">
      {% for r in thesis.risks %}
      <li class="risk">
        <strong>{{ r.name }}</strong>
        {% if r.score is not none %} (score {{ r.score | num(2) }}){% endif %}
        {% if r.reason %}<span class="reason-detail">{{ r.reason }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {% if thesis.base_rate %}
  <div class="base-rate">
    <strong>类比组实证 (panel listed peers, last 24m)</strong>:
    n={{ thesis.base_rate.n_total }} 只
    {% if thesis.base_rate.d30_median is not none %}
      · d30 中位 <span class="{{ thesis.base_rate.d30_median | ret_class }}">{{ thesis.base_rate.d30_median | pct }}</span>
      ({{ "%.0f%%"|format(thesis.base_rate.d30_winrate * 100) }} winrate)
    {% endif %}
    {% if thesis.base_rate.m6_median is not none %}
      · m6 中位 <span class="{{ thesis.base_rate.m6_median | ret_class }}">{{ thesis.base_rate.m6_median | pct }}</span>
      ({{ "%.0f%%"|format(thesis.base_rate.m6_winrate * 100) }} winrate)
    {% endif %}
    · verdict: <strong>{{ thesis.base_rate.verdict }}</strong>
  </div>
  {% endif %}

  {% if thesis.panel_context and thesis.panel_context.regime_label %}
  <div class="base-rate" style="margin-top: 0.4rem;">
    <strong>当下市场情绪</strong>: {{ thesis.panel_context.regime_label }}
    {% if thesis.panel_context.regime_score is not none %}
      (regime_score = {{ thesis.panel_context.regime_score | num(3) }})
    {% endif %}
  </div>
  {% endif %}
</section>
{% endif %}

{# ====== Decision rationale (公式拆解 + band 映射) ====== #}
{% if rec_main.decision_rationale %}
<details open>
  <summary>Decision rationale (公式拆解 + band 映射)</summary>
  <div class="rationale-block">{% for line in rec_main.decision_rationale %}{{ line }}
{% endfor %}</div>
</details>
{% endif %}

{# 三因子分解 #}
<article class="card">
  <h3>三因子分解</h3>
  <table class="numeric">
    <tr>
      <td style="width: 25%;">Q_company</td>
      <td style="width: 15%;">{{ rec_main.Q_company | num(4) }}</td>
      <td><div class="bar"><span style="width: {{ rec_main.Q_company | bar_pct }}%;"></span></div></td>
    </tr>
    <tr>
      <td>Q_ecosystem</td>
      <td>{{ rec_main.Q_ecosystem | num(4) }}</td>
      <td><div class="bar"><span style="width: {{ rec_main.Q_ecosystem | bar_pct }}%;"></span></div></td>
    </tr>
    <tr>
      <td>R_lockup <small style="color: var(--text-muted)">(风险, 越高越糟)</small></td>
      <td>{{ rec_main.R_lockup | num(4) }}</td>
      <td><div class="bar bar-risk"><span style="width: {{ rec_main.R_lockup | bar_pct }}%;"></span></div></td>
    </tr>
  </table>
</article>

{% else %}
{# 多 scenario 表格 (price-scan) #}
<article class="card">
  <h3>定价区间敏感度 (Price scenarios)</h3>
  <table class="numeric compact">
    <thead>
      <tr>
        <th>scenario</th>
        <th class="num">price</th>
        <th>decision</th>
        <th class="num">position</th>
        <th class="num">NACS_adj</th>
        <th class="num">Q_c</th>
        <th class="num">Q_e</th>
        <th class="num">R_l</th>
      </tr>
    </thead>
    <tbody>
      {% for r in records %}
      <tr>
        <td>{{ r.scenario }}</td>
        <td class="num">{{ r.price | num(2) }}</td>
        <td><span class="badge badge-{{ r.decision }}">{{ r.decision }}</span></td>
        <td class="num">{{ "%.0f%%"|format(r.position_pct * 100) }}</td>
        <td class="num">{{ r.nacs_adjusted | num(4) }}</td>
        <td class="num">{{ r.Q_company | num(3) }}</td>
        <td class="num">{{ r.Q_ecosystem | num(3) }}</td>
        <td class="num">{{ r.R_lockup | num(3) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% set decision_set = records | map(attribute="decision") | unique | list %}
  {% if decision_set | length > 1 %}
  <div class="warnings" style="margin-top: 1rem;">
    <h4>⚠ 跨决策边界</h4>
    定价 scenario 间决策不一致: {{ decision_set | join(' / ') }}.
    建议关注定价区间到边时的仓位约束.
  </div>
  {% endif %}
</article>
{% endif %}

{# ====== Adjustments / Warnings ====== #}
{% if rec_main.adjustments_applied %}
<article class="card">
  <h3>调整 (Adjustments)</h3>
  <ul class="adjustments">
    {% for adj in rec_main.adjustments_applied %}
    <li>
      <strong>{{ adj }}</strong>
      {% set expl = rec_main.adjustment_explanations[loop.index0] %}
      {% if expl and expl != adj %}<span class="why">{{ expl }}</span>{% endif %}
    </li>
    {% endfor %}
  </ul>
</article>
{% endif %}

{% if rec_main.warnings %}
<div class="warnings">
  <h4>⚠ Warnings / Vetoes</h4>
  <ul>
    {% for w in rec_main.warnings %}
    <li>{{ w }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

{# ====== L1 / L2 / L3 子项 (折叠), 每子项下显示 reason ====== #}
<details>
  <summary>L1 子项: 公司基本面 (raw {{ rec_main.layer1.raw_score | num(2) }} / 100)</summary>
  <table class="numeric compact">
    <tbody>
      {% for k, v in rec_main.layer1.components.items() %}
        <tr>
          <td><strong>{{ k }}</strong></td>
          <td class="num">{{ v | num(2) }}</td>
        </tr>
        {% if rec_main.layer1.reasons[k] %}
        <tr class="with-reason"><td colspan="2" class="reason">{{ rec_main.layer1.reasons[k] }}</td></tr>
        {% endif %}
      {% endfor %}
      {% if rec_main.layer1.reasons["_veto"] %}
      <tr class="with-reason"><td colspan="2" class="reason"
          style="background: var(--warn-bg); color: var(--warn-text);">
        ⚠ {{ rec_main.layer1.reasons["_veto"] }}
      </td></tr>
      {% endif %}
    </tbody>
  </table>
</details>

<details>
  <summary>L2 子项: 基石生态 (raw {{ rec_main.layer2.raw_score | num(2) }} / 100, cluster_count={{ rec_main.cluster_count }})</summary>
  <table class="numeric compact">
    <tbody>
      {% for k, v in rec_main.layer2.components.items() %}
        <tr>
          <td><strong>{{ k }}</strong></td>
          <td class="num">{% if v is number %}{{ v | num(4) }}{% else %}{{ v }}{% endif %}</td>
        </tr>
        {% if rec_main.layer2.reasons[k] %}
        <tr class="with-reason"><td colspan="2" class="reason">{{ rec_main.layer2.reasons[k] }}</td></tr>
        {% endif %}
      {% endfor %}
      {% if rec_main.layer2.reasons["_veto"] %}
      <tr class="with-reason"><td colspan="2" class="reason"
          style="background: var(--warn-bg); color: var(--warn-text);">
        ⚠ {{ rec_main.layer2.reasons["_veto"] }}
      </td></tr>
      {% endif %}
    </tbody>
  </table>
</details>

<details>
  <summary>L3 子项: 锁定期风险 (R_lockup = {{ rec_main.R_lockup | num(4) }})</summary>
  <table class="numeric compact">
    <tbody>
      {% for k, v in rec_main.layer3.components.items() %}
        <tr>
          <td><strong>{{ k }}</strong></td>
          <td class="num">{% if v is number %}{{ v | num(4) }}{% else %}{{ v }}{% endif %}</td>
        </tr>
        {% if rec_main.layer3.reasons[k] %}
        <tr class="with-reason"><td colspan="2" class="reason">{{ rec_main.layer3.reasons[k] }}</td></tr>
        {% endif %}
      {% endfor %}
    </tbody>
  </table>
</details>

{# ====== Similar listed IPOs ====== #}
{% if similar_cases %}
<article class="card">
  <h3>同伴比对 (Similar listed IPOs · top {{ similar_cases | length }})</h3>
  <table class="numeric compact">
    <thead>
      <tr>
        <th>stock_code</th>
        <th>name</th>
        <th>listing_date</th>
        <th>match</th>
        <th class="num">d30</th>
        <th class="num">m6</th>
      </tr>
    </thead>
    <tbody>
      {% for s in similar_cases %}
      <tr>
        <td><code>{{ s.stock_code }}</code></td>
        <td>{{ s.name or '' }}</td>
        <td>{{ s.listing_date | fmt_date }}</td>
        <td><small style="color: var(--text-muted);">{{ s.match_dims | join('+') }}</small></td>
        <td class="num {{ s.actual_d30 | ret_class }}">{{ s.actual_d30 | pct }}</td>
        <td class="num {{ s.actual_m6 | ret_class }}">{{ s.actual_m6 | pct }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</article>
{% endif %}

{# ====== Inputs snapshot (audit) ====== #}
<details>
  <summary>Inputs snapshot (audit · 当时模型看到的全部输入)</summary>
  <pre>{{ rec_main.offering_inputs | json_dump }}</pre>
</details>

{% endblock %}
