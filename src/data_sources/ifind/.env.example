# ============================================================
# iFinD (同花顺 QuantAPI) 凭证模板 —— 复制为 .env 后填入实际值
# 文档: https://quantapi.10jqka.com.cn/gws/static/static/ds_web/quantapi-web/
# ============================================================

# 登录账号 / 密码（对应 iFinDPy 的 THS_iFinDLogin(username, password)）
IFIND_USERNAME=your_username_here
IFIND_PASSWORD=your_password_here

# 可选：若使用 refresh token 方式登录，填这里
IFIND_REFRESH_TOKEN=

# 可选：覆盖输出目录（默认写到 项目根/data/raw/ifind/）
# IFIND_OUTPUT_DIR=
